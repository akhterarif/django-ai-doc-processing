# Django
SECRET_KEY=django-insecure-change-me-in-production

# Database
DATABASE_URL=postgresql://doc_processor_user:doc_processor_password@db:5432/doc_processor_db

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# AI / LLM — Ollama local (no API key required)
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=phi4
LLM_TIMEOUT_SECONDS=120
# To use OpenAI or any other OpenAI-compatible provider instead:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o
#   LLM_API_KEY=sk-...

# Webhooks (optional)
# WEBHOOK_URL=https://your-service.example.com/webhook

# AWS S3 (optional — for production media storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
